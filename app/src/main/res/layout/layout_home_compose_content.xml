<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nestedScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?custom_background_color_dark"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/linearLayout_home_announcements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_3"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/linearLayout_home_collection_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_3"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/linearLayout_home_collection_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_3"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/linearLayout_home_collection_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_3"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/linearLayout_home_collection_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_3"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/linearLayout_home_collection_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_3"
            android:layout_marginBottom="@dimen/padding_2"
            android:orientation="vertical" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
