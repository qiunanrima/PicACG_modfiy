<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Android 9+ 默认禁止明文 HTTP，此配置允许 cleartext 以保持与服务端兼容 -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
