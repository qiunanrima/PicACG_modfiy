<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <inset
            android:insetLeft="@dimen/padding_1"
            android:insetTop="@dimen/padding_1"
            android:insetRight="@dimen/padding_1"
            android:insetBottom="@dimen/padding_1">
            <shape android:shape="rectangle">
                <corners android:radius="@dimen/size_expressive_corner_medium" />
                <gradient
                    android:angle="0"
                    android:endColor="@color/expressive_primary_dark"
                    android:startColor="@color/expressive_primary" />
            </shape>
        </inset>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/size_expressive_corner_medium" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
