<?xml version="1.0" encoding="utf-8" standalone="no"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    platformBuildVersionCode="44"
    platformBuildVersionName="2.2.1.3.3.4">

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <uses-permission-sdk-23 android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission-sdk-23 android:name="android.permission.RECORD_AUDIO" />
    <uses-permission-sdk-23 android:name="android.permission.WRITE_SETTINGS" />

    <application
        android:name="com.picacomic.fregata.MyApplication"
        android:allowBackup="true"
        android:hardwareAccelerated="true"
        android:icon="@drawable/logo_round"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <meta-data
            android:name="DATABASE"
            android:value="com_picacomic_fregata.db" />
        <meta-data
            android:name="VERSION"
            android:value="2" />
        <meta-data
            android:name="QUERY_LOG"
            android:value="true" />
        <meta-data
            android:name="DOMAIN_PACKAGE_NAME"
            android:value="com.picacomic.fregata" />

        <activity
            android:name="com.picacomic.fregata.DemoLoginActivity"
            android:label="@string/app_name" />
        <activity
            android:name="com.picacomic.fregata.activities.LoginActivity"
            android:label="@string/app_name"
            android:screenOrientation="portrait" />
        <activity android:name="com.picacomic.fregata.activities.BaseActivity" />
        <activity
            android:name="com.picacomic.fregata.activities.MainActivity"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:label="@string/title_activity_main" />
        <activity
            android:name="com.picacomic.fregata.activities.ComicViewerActivity"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:label="@string/title_activity_comic_viewer"
            android:screenOrientation="sensorPortrait"
            android:theme="@style/AppTheme" />
        <activity android:name="com.picacomic.fregata.activities.ImageCropActivity" />
        <activity android:name="com.picacomic.fregata.activities.PopupActivity" />

        <service
            android:name="com.picacomic.fregata.services.ChatroomService"
            android:enabled="true"
            android:exported="true" />
        <service android:name="com.picacomic.fregata.services.DownloadService" />

        <activity
            android:name="com.picacomic.fregata.activities.SplashActivity"
            android:label="@string/app_name"
            android:screenOrientation="sensorPortrait" />
        <activity-alias
            android:name="com.picacomic.fregata.alias.Default"
            android:enabled="true"
            android:exported="true"
            android:icon="@drawable/logo_round"
            android:label="@string/app_name"
            android:targetActivity="com.picacomic.fregata.activities.SplashActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name="com.picacomic.fregata.alias.Neon"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/logo_round_neon"
            android:label="@string/app_name"
            android:targetActivity="com.picacomic.fregata.activities.SplashActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <receiver android:name="com.just.agentweb.download.NotificationCancelReceiver" />
        <activity
            android:name="com.just.agentweb.ActionActivity"
            android:configChanges="keyboardHidden|orientation|screenSize"
            android:exported="false"
            android:launchMode="standard"
            android:theme="@style/AppTheme"
            android:windowSoftInputMode="stateAlwaysHidden" />
    </application>
</manifest>
